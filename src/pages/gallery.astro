---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import GalleryGrid from '../components/GalleryGrid.astro';
import { getGalleryItems } from '../lib/content';

const gallery = await getGalleryItems();
const images = gallery.map((item) => ({
  title: item.data.title,
  image: item.data.image,
  alt: item.data.alt,
  caption: item.data.caption,
  artistSlug: item.data.artistSlug,
}));
---
<BaseLayout title="Gallery" description="Browse artwork by members of the Creative Arts Association of Lakewood Ranch.">
  <Hero title="Gallery" subtitle="Artwork by CAALR members" compact />

  <section class="section">
    <div class="container">
      <GalleryGrid images={images} />
    </div>
  </section>
</BaseLayout>
