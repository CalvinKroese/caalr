---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { formatDate, isUpcoming } from '../../lib/content';

export async function getStaticPaths() {
  const events = await getCollection('events');
  return events.map((event) => ({
    params: { slug: event.id },
    props: { event },
  }));
}

const { event } = Astro.props;
const { Content } = await event.render();
const { title, startDate, endDate, venueName, venueAddress, featuredImage, galleryImages } = event.data;
const upcoming = isUpcoming(startDate);
const mapsUrl = venueAddress ? `https://maps.google.com/?q=${encodeURIComponent(venueAddress)}` : '';
---
<BaseLayout title={title} description={`${title} — ${formatDate(startDate)} at ${venueName}`}>
  <section class="section">
    <div class="container event-detail">
      <div class="event-detail__header">
        <span class:list={['badge', { 'badge--upcoming': upcoming }]}>
          {upcoming ? 'Upcoming' : 'Past'}
        </span>
        <h1>{title}</h1>
        <div class="event-detail__meta">
          <p><strong>Date:</strong> {formatDate(startDate)}{endDate && endDate.getTime() !== startDate.getTime() && ` — ${formatDate(endDate)}`}</p>
          <p><strong>Venue:</strong> {venueName}</p>
          {venueAddress && (
            <p>
              {venueAddress}
              {mapsUrl && <> — <a href={mapsUrl} target="_blank" rel="noopener noreferrer">View on Google Maps</a></>}
            </p>
          )}
        </div>
      </div>

      {featuredImage && (
        <img src={featuredImage} alt={title} class="event-detail__image" width="800" height="400" />
      )}

      <div class="prose">
        <Content />
      </div>

      {galleryImages && galleryImages.length > 0 && (
        <div class="event-detail__photos">
          <h2>Event Photos</h2>
          <div class="grid grid--3">
            {galleryImages.map((img, i) => (
              <img src={img} alt={`${title} photo ${i + 1}`} class="card__image" loading="lazy" style="border-radius: var(--radius-card)" />
            ))}
          </div>
        </div>
      )}

      <div style="margin-top: var(--space-lg)">
        <a href="/events/" class="btn btn--primary">&larr; All Events</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .event-detail__header {
    margin-bottom: var(--space-lg);
  }

  .event-detail__header h1 {
    margin-top: var(--space-sm);
  }

  .event-detail__meta {
    color: var(--color-text-muted);
  }

  .event-detail__meta p {
    margin-bottom: var(--space-xs);
  }

  .event-detail__image {
    width: 100%;
    max-height: 400px;
    object-fit: cover;
    border-radius: var(--radius-card);
    margin-bottom: var(--space-lg);
  }

  .event-detail__photos {
    margin-top: var(--space-xl);
  }

  .badge--upcoming {
    background-color: var(--color-secondary-light);
    color: var(--color-secondary);
  }
</style>
