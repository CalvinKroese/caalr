---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page Not Found">
  <section class="section" style="text-align: center; min-height: 50vh; display: flex; align-items: center; justify-content: center;">
    <div class="container">
      <p class="script script--lg" style="color: var(--color-coral); margin-bottom: 0;">oops!</p>
      <h1 style="font-size: var(--font-size-4xl); color: var(--color-teal); margin-bottom: var(--space-sm);">404</h1>
      <p style="font-size: var(--font-size-xl); margin-bottom: var(--space-sm);">This page wandered off to the art studio</p>
      <p class="text-muted" style="margin-bottom: var(--space-lg);">The page you're looking for doesn't exist or has been moved.</p>
      <a href="/" class="btn btn--coral">Back to Home</a>
    </div>
  </section>
</BaseLayout>
