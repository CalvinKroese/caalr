---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ArtistCard from '../components/ArtistCard.astro';
import { getActiveArtists, getUpcomingEvents, getFeaturedGallery } from '../lib/content';

const artists = await getActiveArtists();
const upcomingEvents = await getUpcomingEvents();
const featuredGallery = await getFeaturedGallery(6);
---
<BaseLayout title="Welcome">

  {/* Split hero — text left, rotating ART photos right */}
  <section class="split-hero">
    <div class="container split-hero__inner">
      <div class="split-hero__text">
        <p class="script script--lg" style="color: var(--color-coral);">welcome to</p>
        <h1>Creative Arts Association of Lakewood Ranch</h1>
        <p>A vibrant community of visual artists sharing their passion through exhibitions, education, and friendship since 2001</p>
        <div class="split-hero__actions">
          <a href="/artists/" class="btn btn--coral">Meet Our Artists</a>
          <a href="/events/" class="btn btn--outline">Upcoming Shows</a>
        </div>
      </div>
      <div class="split-hero__slideshow">
        <img src="/uploads/gallery/gallery-001.jpg" alt="Stained Glass artwork" class="slideshow-img active" />
        <img src="/uploads/gallery/gallery-004.jpg" alt="Watercolor artwork" class="slideshow-img" />
        <img src="/uploads/gallery/gallery-010.jpg" alt="Raku Pottery" class="slideshow-img" />
        <img src="/uploads/gallery/gallery-020.jpg" alt="Jewelry artwork" class="slideshow-img" />
        <img src="/uploads/gallery/gallery-026.jpg" alt="Mixed Media artwork" class="slideshow-img" />
        <img src="/uploads/gallery/gallery-032.jpg" alt="Fiberware artwork" class="slideshow-img" />
        <img src="/uploads/gallery/gallery-049.jpg" alt="Resin Art" class="slideshow-img" />
        <img src="/uploads/gallery/gallery-017.jpg" alt="Pottery" class="slideshow-img" />
      </div>
    </div>
  </section>

  {/* Upcoming event banner */}
  {upcomingEvents.length > 0 && (
    <section class="exhibition-banner">
      <div class="container exhibition-banner__inner">
        <div class="exhibition-banner__label">
          <span class="script">upcoming</span>
          <span class="exhibition-banner__dot"></span>
        </div>
        <div class="exhibition-banner__info">
          <h2>{upcomingEvents[0].data.title}</h2>
          <p>{upcomingEvents[0].data.venueName}</p>
        </div>
        <a href={`/events/${upcomingEvents[0].id.replace(/\.md$/, '')}/`} class="btn btn--outline">View Details</a>
      </div>
    </section>
  )}

  {/* Our Story — people slideshow LEFT, text RIGHT (flipped direction) */}
  <section class="section section--warm">
    <div class="container story-section">
      <div class="story-section__slideshow">
        <img src="/uploads/people/show-015.jpg" alt="Community enjoying an art show" class="people-img active" />
        <img src="/uploads/people/show-012.jpg" alt="Guests browsing artwork" class="people-img" />
        <img src="/uploads/people/show-013.jpg" alt="Artist with stained glass" class="people-img" />
        <img src="/uploads/people/show-014.jpg" alt="Community at exhibition" class="people-img" />
        <img src="/uploads/people/show-006.jpg" alt="Artist at gallery" class="people-img" />
        <img src="/uploads/people/show-009.jpg" alt="Art show visitors" class="people-img" />
      </div>
      <div class="story-section__text">
        <p class="script script--lg" style="color: var(--color-coral); margin-bottom: 0;">our story</p>
        <h2>From a Park to a Community</h2>
        <p>In 2001, a handful of Lakewood Ranch artists began gathering in a local park — easels and sketchbooks in hand. From those humble beginnings, CAALR grew to include approximately 20 working artist members and over 50 supporting members.</p>
        <p>Since 2002, we've hosted seasonal art shows that bring together artists working in watercolor, pottery, jewelry, stained glass, fiber art, mixed media, and more. Our 2015 Fall Art Show attracted over 500 guests!</p>
        <a href="/about/" class="btn btn--outline" style="margin-top: var(--space-xs);">Learn More About Us</a>
      </div>
    </div>
  </section>

  {/* Artists */}
  {artists.length > 0 && (
    <section class="section">
      <div class="container">
        <SectionHeading label="meet our" title="Artists" subtitle="Talented artists working across many mediums" />
        <div class="grid grid--4">
          {artists.slice(0, 8).map((artist) => (
            <ArtistCard name={artist.data.name} slug={artist.id.replace(/\.md$/, '')} mediums={artist.data.mediums} shortBio={artist.data.shortBio} featuredImage={artist.data.featuredImage} photoIsTemp={artist.data.photoIsTemp} />
          ))}
        </div>
        <div class="text-center" style="margin-top: var(--space-md);">
          <a href="/artists/" class="btn btn--primary">View All {artists.length} Artists</a>
        </div>
      </div>
    </section>
  )}

  {/* Gallery Preview */}
  {featuredGallery.length > 0 && (
    <section class="section section--alt">
      <div class="container">
        <SectionHeading label="from the studio" title="Gallery" subtitle="Recent works by our members" />
        <div class="gallery-preview">
          {featuredGallery.map((item) => (
            <div class="gallery-preview__item">
              <img src={item.data.image} alt={item.data.alt} loading="lazy" width="400" height="400" />
            </div>
          ))}
        </div>
        <div class="text-center" style="margin-top: var(--space-md);">
          <a href="/gallery/" class="btn btn--secondary">View Full Gallery</a>
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  /* Split hero */
  .split-hero {
    background: var(--color-sunshine);
    padding: var(--space-lg) 0;
  }
  .split-hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
    align-items: center;
  }
  .split-hero__text h1 {
    font-size: var(--font-size-3xl);
    color: var(--color-green-dark);
    margin-bottom: var(--space-sm);
  }
  .split-hero__text p {
    color: var(--color-drift);
    margin-bottom: var(--space-sm);
  }
  .split-hero__actions {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }
  .split-hero__slideshow {
    position: relative;
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    aspect-ratio: 4/3;
  }
  .slideshow-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 1.5s ease;
  }
  .slideshow-img.active { opacity: 1; }

  /* Exhibition banner */
  .exhibition-banner {
    background: var(--color-green-dark);
    color: white;
    padding: var(--space-md) 0;
  }
  .exhibition-banner__inner {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }
  .exhibition-banner__label {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    flex-shrink: 0;
  }
  .exhibition-banner__label .script { color: var(--color-gold-bright); font-size: var(--font-size-lg); }
  .exhibition-banner__dot {
    width: 8px;
    height: 8px;
    background: var(--color-coral);
    border-radius: 50%;
    animation: pulse 2s infinite;
  }
  @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }
  .exhibition-banner__info { flex: 1; }
  .exhibition-banner__info h2 { font-size: var(--font-size-lg); margin: 0; color: white; }
  .exhibition-banner__info p { margin: 0; opacity: 0.8; font-size: var(--font-size-sm); }
  .exhibition-banner .btn--outline { border-color: rgba(255,255,255,0.5); color: white; white-space: nowrap; }
  .exhibition-banner .btn--outline:hover { border-color: white; background: rgba(255,255,255,0.1); }

  @media (max-width: 768px) {
    .split-hero__inner { grid-template-columns: 1fr; }
    .split-hero__text h1 { font-size: var(--font-size-2xl); }
  }

  /* Story section — photos LEFT, text RIGHT */
  .story-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
    align-items: center;
  }
  .story-section__slideshow {
    position: relative;
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    aspect-ratio: 4/3;
  }
  .people-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 1.2s ease;
  }
  .people-img.active { opacity: 1; }
  @media (max-width: 768px) {
    .story-section { grid-template-columns: 1fr; }
    .story-section__slideshow { order: -1; }
  }

  /* Gallery preview */
  .gallery-preview {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-sm);
  }
  .gallery-preview__item {
    border-radius: var(--radius-card);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .gallery-preview__item:hover {
    transform: scale(1.02);
    box-shadow: var(--shadow-card-hover);
  }
  .gallery-preview__item img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
  }
  .gallery-preview__item:first-child { grid-row: span 2; }
  .gallery-preview__item:first-child img { aspect-ratio: auto; height: 100%; }
  @media (max-width: 600px) {
    .gallery-preview { grid-template-columns: repeat(2, 1fr); }
    .gallery-preview__item:first-child { grid-row: span 1; }
  }
</style>

<script is:inline>
  // Art slideshow (hero)
  const artImgs = document.querySelectorAll('.slideshow-img');
  if (artImgs.length > 1) {
    let current = 0;
    setInterval(() => {
      artImgs[current].classList.remove('active');
      current = (current + 1) % artImgs.length;
      artImgs[current].classList.add('active');
    }, 4000);
  }

  // People slideshow (story section)
  const peopleImgs = document.querySelectorAll('.people-img');
  if (peopleImgs.length > 1) {
    let current = 0;
    setInterval(() => {
      peopleImgs[current].classList.remove('active');
      current = (current + 1) % peopleImgs.length;
      peopleImgs[current].classList.add('active');
    }, 5000);
  }
</script>
