---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ArtistCard from '../components/ArtistCard.astro';
import EventCard from '../components/EventCard.astro';
import { getActiveArtists, getUpcomingEvents, getFeaturedGallery } from '../lib/content';

const artists = await getActiveArtists();
const featuredArtists = artists.slice(0, 4);
const upcomingEvents = await getUpcomingEvents();
const featuredGallery = await getFeaturedGallery(6);
---
<BaseLayout title="Welcome">
  <!-- Hero with art collage background -->
  <Hero
    title="Creative Arts Association of Lakewood Ranch"
    subtitle="A vibrant community of visual artists sharing their passion through exhibitions, education, and friendship since 2001"
    scriptLabel="welcome to"
    image="/uploads/people/show-015.jpg"
    cta={{ label: 'Meet Our Artists', href: '/artists/', variant: 'coral' }}
  />

  <!-- Our Story section -->
  <section class="section section--warm">
    <div class="container story-section">
      <div class="story-section__text">
        <p class="script script--lg story-section__label">our story</p>
        <h2>From a Park to a Community</h2>
        <p>
          In 2001, a handful of Lakewood Ranch artists began gathering in a local park —
          easels and sketchbooks in hand, eager to share their creative journeys. From those
          humble beginnings, the Creative Arts Association of Lakewood Ranch grew into a
          recognized community of approximately 20 working artist members and over 50
          supporting members.
        </p>
        <p>
          Since 2002, we've hosted seasonal art shows that bring together artists working in
          watercolor, pottery, jewelry, stained glass, fiber art, mixed media, and more. Our
          2015 Fall Art Show attracted over 500 guests!
        </p>
        <p>
          Whether you're an artist looking for community or an art lover looking for
          inspiration, you're welcome here.
        </p>
        <a href="/about/" class="btn btn--outline">Learn More About Us</a>
      </div>
      <div class="story-section__images">
        <img
          src="/uploads/people/show-014.jpg"
          alt="CAALR members and guests at an art show"
          class="story-section__img story-section__img--main"
          loading="lazy"
        />
        <img
          src="/uploads/people/show-012.jpg"
          alt="Community members enjoying art at a CAALR exhibition"
          class="story-section__img story-section__img--accent"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- Community Photo Collage -->
  <section class="section">
    <div class="container">
      <SectionHeading
        label="our community"
        title="Art Brings Us Together"
      />
      <div class="photo-collage">
        <div class="photo-collage__item photo-collage__item--wide">
          <img src="/uploads/people/show-015.jpg" alt="Community members enjoying a CAALR art show" loading="lazy" />
        </div>
        <div class="photo-collage__item">
          <img src="/uploads/people/show-013.jpg" alt="Artist standing with their stained glass artwork" loading="lazy" />
        </div>
        <div class="photo-collage__item">
          <img src="/uploads/people/show-006.jpg" alt="Artist at gallery exhibition" loading="lazy" />
        </div>
        <div class="photo-collage__item photo-collage__item--wide">
          <img src="/uploads/people/show-012.jpg" alt="Guests browsing artwork at a CAALR exhibition" loading="lazy" />
        </div>
        <div class="photo-collage__item">
          <img src="/uploads/gallery/gallery-002.jpg" alt="Artwork by a CAALR member" loading="lazy" />
        </div>
        <div class="photo-collage__item">
          <img src="/uploads/gallery/gallery-004.jpg" alt="Artwork by a CAALR member" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Upcoming Events -->
  {upcomingEvents.length > 0 && (
    <section class="section section--alt">
      <div class="container">
        <SectionHeading
          label="mark your calendar"
          title="Upcoming Shows"
          subtitle="Join us at our next event — free admission and parking"
        />
        <div class="grid grid--3">
          {upcomingEvents.slice(0, 3).map((event) => (
            <EventCard
              title={event.data.title}
              slug={event.id.replace(/\.md$/, '')}
              startDate={event.data.startDate}
              venueName={event.data.venueName}
              featuredImage={event.data.featuredImage}
            />
          ))}
        </div>
        <div class="text-center" style="margin-top: var(--space-md)">
          <a href="/events/" class="btn btn--outline">All Events</a>
        </div>
      </div>
    </section>
  )}

  <!-- Stats strip -->
  <section class="section--accent stats-strip">
    <div class="container stats-strip__inner">
      <div class="stats-strip__item">
        <span class="stats-strip__number">2001</span>
        <span class="stats-strip__label">Founded</span>
      </div>
      <div class="stats-strip__item">
        <span class="stats-strip__number">20+</span>
        <span class="stats-strip__label">Artist Members</span>
      </div>
      <div class="stats-strip__item">
        <span class="stats-strip__number">50+</span>
        <span class="stats-strip__label">Supporters</span>
      </div>
      <div class="stats-strip__item">
        <span class="stats-strip__number">500+</span>
        <span class="stats-strip__label">Show Guests</span>
      </div>
    </div>
  </section>

  <!-- Featured Artists -->
  {featuredArtists.length > 0 && (
    <section class="section section--alt">
      <div class="container">
        <SectionHeading
          label="meet our artists"
          title="Featured Members"
          subtitle="Talented artists working in pottery, jewelry, watercolor, stained glass, and more"
        />
        <div class="grid grid--4">
          {featuredArtists.map((artist) => (
            <ArtistCard
              name={artist.data.name}
              slug={artist.id.replace(/\.md$/, '')}
              mediums={artist.data.mediums}
              shortBio={artist.data.shortBio}
              featuredImage={artist.data.featuredImage}
            />
          ))}
        </div>
        <div class="text-center" style="margin-top: var(--space-md)">
          <a href="/artists/" class="btn btn--primary">All Artists</a>
        </div>
      </div>
    </section>
  )}

  <!-- Gallery Preview -->
  {featuredGallery.length > 0 && (
    <section class="section">
      <div class="container">
        <SectionHeading
          label="from the studio"
          title="Gallery"
          subtitle="Recent works by our members"
        />
        <div class="gallery-preview">
          {featuredGallery.map((item) => (
            <div class="gallery-preview__item">
              <img
                src={item.data.image}
                alt={item.data.alt}
                loading="lazy"
                width="400"
                height="400"
              />
            </div>
          ))}
        </div>
        <div class="text-center" style="margin-top: var(--space-md)">
          <a href="/gallery/" class="btn btn--secondary">View Full Gallery</a>
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  /* Story section — two column with art photos */
  .story-section {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    align-items: center;
  }

  @media (min-width: 768px) {
    .story-section {
      grid-template-columns: 1fr 1fr;
    }
  }

  .story-section__label {
    color: var(--color-coral);
    margin-bottom: 0;
  }

  .story-section__text h2 {
    margin-bottom: var(--space-sm);
  }

  .story-section__images {
    position: relative;
    min-height: 350px;
  }

  .story-section__img {
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
  }

  .story-section__img--main {
    width: 85%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .story-section__img--accent {
    position: absolute;
    bottom: -20px;
    right: 0;
    width: 55%;
    aspect-ratio: 1;
    object-fit: cover;
    border: 4px solid var(--color-sand);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
  }

  /* Stats strip */
  .stats-strip {
    padding-block: var(--space-lg);
  }

  .stats-strip__inner {
    display: flex;
    justify-content: space-around;
    flex-wrap: wrap;
    gap: var(--space-md);
    text-align: center;
  }

  .stats-strip__item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .stats-strip__number {
    font-family: var(--font-heading);
    font-size: var(--font-size-3xl);
    font-weight: 700;
    color: var(--color-gold);
  }

  .stats-strip__label {
    font-size: var(--font-size-sm);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.8;
  }

  /* Photo collage */
  .photo-collage {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-sm);
  }

  .photo-collage__item {
    border-radius: var(--radius-card);
    overflow: hidden;
    box-shadow: var(--shadow-card);
  }

  .photo-collage__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    min-height: 200px;
    transition: transform 0.3s ease;
  }

  .photo-collage__item:hover img {
    transform: scale(1.05);
  }

  .photo-collage__item--wide {
    grid-column: span 2;
  }

  @media (max-width: 600px) {
    .photo-collage {
      grid-template-columns: repeat(2, 1fr);
    }
    .photo-collage__item--wide {
      grid-column: span 2;
    }
  }

  /* Gallery preview — varied sizes */
  .gallery-preview {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-sm);
  }

  .gallery-preview__item {
    border-radius: var(--radius-card);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .gallery-preview__item:hover {
    transform: scale(1.02);
    box-shadow: var(--shadow-card-hover);
  }

  .gallery-preview__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 1;
  }

  /* Make first image span 2 rows for visual variety */
  .gallery-preview__item:first-child {
    grid-row: span 2;
  }

  .gallery-preview__item:first-child img {
    aspect-ratio: auto;
  }

  @media (max-width: 600px) {
    .gallery-preview {
      grid-template-columns: repeat(2, 1fr);
    }
    .gallery-preview__item:first-child {
      grid-row: span 1;
    }
  }
</style>
