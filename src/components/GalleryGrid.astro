---
interface GalleryImage {
  title: string;
  image: string;
  alt: string;
  artistSlug?: string;
}

interface Props {
  images: GalleryImage[];
}

const { images } = Astro.props;
---

{images.length > 0 ? (
  <div class="gallery-grid" role="list">
    {images.map((img, i) => (
      <button
        class="gallery-grid__item"
        role="listitem"
        data-index={i}
        data-src={img.image}
        data-alt={img.alt}
        data-title={img.title}
        aria-label={`View ${img.title}: ${img.alt}`}
      >
        <img
          src={img.image}
          alt={img.alt}
          loading="lazy"
          width="400"
          height="300"
          class="gallery-grid__img"
        />
        <span class="gallery-grid__caption">{img.title}</span>
      </button>
    ))}
  </div>

  <dialog id="lightbox" class="lightbox" aria-label="Image viewer">
    <div class="lightbox__inner">
      <button class="lightbox__close" aria-label="Close image viewer">&times;</button>
      <button class="lightbox__prev" aria-label="Previous image">&lsaquo;</button>
      <button class="lightbox__next" aria-label="Next image">&rsaquo;</button>
      <img class="lightbox__img" src="" alt="" />
      <p class="lightbox__caption"></p>
    </div>
  </dialog>

  <script>
    const grid = document.querySelector('.gallery-grid');
    const dialog = document.getElementById('lightbox') as HTMLDialogElement;
    const img = dialog?.querySelector('.lightbox__img') as HTMLImageElement;
    const caption = dialog?.querySelector('.lightbox__caption') as HTMLParagraphElement;
    const items = Array.from(document.querySelectorAll('.gallery-grid__item'));
    let current = 0;

    function show(index: number) {
      if (!dialog || !img || !caption) return;
      current = index;
      const el = items[index] as HTMLElement;
      img.src = el.dataset.src || '';
      img.alt = el.dataset.alt || '';
      caption.textContent = el.dataset.title || '';
      if (!dialog.open) dialog.showModal();
    }

    function navigate(dir: number) {
      const next = (current + dir + items.length) % items.length;
      show(next);
    }

    grid?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.gallery-grid__item') as HTMLElement;
      if (btn) show(Number(btn.dataset.index));
    });

    dialog?.querySelector('.lightbox__close')?.addEventListener('click', () => dialog.close());
    dialog?.querySelector('.lightbox__prev')?.addEventListener('click', () => navigate(-1));
    dialog?.querySelector('.lightbox__next')?.addEventListener('click', () => navigate(1));

    dialog?.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') navigate(-1);
      if (e.key === 'ArrowRight') navigate(1);
      if (e.key === 'Escape') dialog.close();
    });

    dialog?.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });
  </script>
) : (
  <p class="text-muted text-center">No gallery images yet.</p>
)}

<style>
  .gallery-grid {
    columns: 2;
    column-gap: var(--space-sm);
  }

  @media (min-width: 768px) {
    .gallery-grid { columns: 3; }
  }

  @media (min-width: 1024px) {
    .gallery-grid { columns: 4; }
  }

  .gallery-grid__item {
    display: block;
    width: 100%;
    break-inside: avoid;
    margin-bottom: var(--space-sm);
    border: none;
    padding: 0;
    background: none;
    cursor: pointer;
    border-radius: var(--radius-card);
    overflow: hidden;
    position: relative;
  }

  .gallery-grid__item:hover .gallery-grid__img {
    transform: scale(1.03);
  }

  .gallery-grid__img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.2s ease;
  }

  .gallery-grid__caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-xs) var(--space-sm);
    background: linear-gradient(transparent, rgba(0,0,0,0.7));
    color: white;
    font-size: var(--font-size-sm);
  }

  /* Lightbox */
  .lightbox {
    border: none;
    background: rgba(0, 0, 0, 0.9);
    max-width: 100vw;
    max-height: 100vh;
    width: 100%;
    height: 100%;
    padding: 0;
  }

  .lightbox::backdrop {
    background: rgba(0, 0, 0, 0.9);
  }

  .lightbox__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    position: relative;
  }

  .lightbox__img {
    max-width: 90vw;
    max-height: 85vh;
    object-fit: contain;
  }

  .lightbox__close,
  .lightbox__prev,
  .lightbox__next {
    position: absolute;
    background: none;
    border: none;
    color: white;
    font-size: 2rem;
    cursor: pointer;
    padding: var(--space-sm);
    z-index: 10;
    opacity: 0.7;
    transition: opacity 0.15s;
  }

  .lightbox__close:hover,
  .lightbox__prev:hover,
  .lightbox__next:hover {
    opacity: 1;
  }

  .lightbox__close {
    top: var(--space-sm);
    right: var(--space-sm);
    font-size: 2.5rem;
  }

  .lightbox__prev { left: var(--space-sm); top: 50%; transform: translateY(-50%); font-size: 3rem; }
  .lightbox__next { right: var(--space-sm); top: 50%; transform: translateY(-50%); font-size: 3rem; }

  .lightbox__caption {
    position: absolute;
    bottom: var(--space-md);
    left: 50%;
    transform: translateX(-50%);
    color: white;
    font-size: var(--font-size-base);
    text-align: center;
    max-width: 80%;
  }
</style>
