---
interface Props {
  title: string;
  subtitle?: string;
  scriptLabel?: string;
  image?: string;
  cta?: {
    label: string;
    href: string;
    variant?: string;
  };
  compact?: boolean;
}

const { title, subtitle, scriptLabel, image, cta, compact = false } = Astro.props;
---

<section class:list={['hero', { 'hero--compact': compact, 'hero--with-image': !!image }]}>
  {image && <div class="hero__bg" style={`background-image: url('${image}')`}></div>}
  <div class="hero__overlay"></div>
  <div class="container hero__content">
    {scriptLabel && <p class="hero__label script">{scriptLabel}</p>}
    <h1 class="hero__title">{title}</h1>
    {subtitle && <p class="hero__subtitle">{subtitle}</p>}
    {cta && (
      <a href={cta.href} class:list={['btn', `btn--${cta.variant || 'coral'}`, 'hero__cta']}>{cta.label}</a>
    )}
  </div>
</section>

<style>
  .hero {
    position: relative;
    background-color: var(--color-teal-deeper);
    color: white;
    padding-block: var(--space-xl) calc(var(--space-xl) * 1.5);
    overflow: hidden;
  }

  .hero--compact {
    padding-block: var(--space-lg) calc(var(--space-lg) * 1.25);
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0.25;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(5, 77, 85, 0.85) 0%,
      rgba(14, 154, 167, 0.7) 50%,
      rgba(5, 77, 85, 0.8) 100%
    );
  }

  .hero__content {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 800px;
    margin-inline: auto;
  }

  .hero__label {
    color: var(--color-coral);
    margin-bottom: 0;
    font-size: 2rem;
  }

  .hero__title {
    font-size: var(--font-size-4xl);
    color: white;
    margin-bottom: var(--space-sm);
  }

  .hero--compact .hero__title {
    font-size: var(--font-size-3xl);
  }

  .hero__subtitle {
    font-size: var(--font-size-lg);
    opacity: 0.9;
    margin-bottom: var(--space-md);
    line-height: 1.6;
    max-width: 600px;
    margin-inline: auto;
  }

  .hero__cta {
    margin-top: var(--space-xs);
  }

  @media (max-width: 768px) {
    .hero__title {
      font-size: var(--font-size-2xl);
    }
    .hero--compact .hero__title {
      font-size: var(--font-size-xl);
    }
    .hero__label {
      font-size: 1.5rem;
    }
  }
</style>
