---
interface Props {
  title: string;
  subtitle?: string;
  scriptLabel?: string;
  image?: string;
  cta?: {
    label: string;
    href: string;
    variant?: string;
  };
  compact?: boolean;
}

const { title, subtitle, scriptLabel, image, cta, compact = false } = Astro.props;
---

<section class:list={['hero', { 'hero--compact': compact, 'hero--with-image': !!image }]}>
  {image && <div class="hero__bg" style={`background-image: url('${image}')`}></div>}
  <div class="container hero__content">
    {scriptLabel && <p class="hero__label script">{scriptLabel}</p>}
    <h1 class="hero__title">{title}</h1>
    {subtitle && <p class="hero__subtitle">{subtitle}</p>}
    {cta && (
      <a href={cta.href} class:list={['btn', `btn--${cta.variant || 'coral'}`, 'hero__cta']}>{cta.label}</a>
    )}
  </div>
</section>

<style>
  .hero {
    position: relative;
    background-color: var(--color-driftwood);
    color: var(--color-charcoal);
    padding-block: var(--space-lg);
    overflow: hidden;
  }

  .hero--compact {
    padding-block: var(--space-md) var(--space-lg);
  }

  .hero--with-image {
    color: white;
    background-color: var(--color-green-deeper);
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0.4;
  }

  .hero__content {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 800px;
    margin-inline: auto;
  }

  .hero__label {
    color: var(--color-coral);
    margin-bottom: 0;
    font-size: 1.75rem;
  }

  .hero--with-image .hero__label {
    color: var(--color-gold-bright);
  }

  .hero__title {
    font-size: var(--font-size-3xl);
    color: var(--color-green-dark);
    margin-bottom: var(--space-xs);
  }

  .hero--with-image .hero__title {
    color: white;
  }

  .hero--compact .hero__title {
    font-size: var(--font-size-2xl);
  }

  .hero__subtitle {
    font-size: var(--font-size-base);
    opacity: 0.85;
    margin-bottom: var(--space-sm);
    line-height: 1.6;
    max-width: 600px;
    margin-inline: auto;
  }

  .hero__cta {
    margin-top: var(--space-xs);
  }

  @media (max-width: 768px) {
    .hero__title {
      font-size: var(--font-size-2xl);
    }
    .hero--compact .hero__title {
      font-size: var(--font-size-xl);
    }
    .hero__label {
      font-size: 1.375rem;
    }
  }
</style>
